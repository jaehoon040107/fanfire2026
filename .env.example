# ─────────────────────────────────────────────────────────
# FANFIRE 환경변수 — 배포 시 실제 키로 교체
# 이 파일은 템플릿(.env.example)이며 git에 커밋됩니다.
# 실제 키는 .env.local 에 넣으세요 (git ignore 됨).
# ─────────────────────────────────────────────────────────

# Supabase (https://app.supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# football-data.org (https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=your-football-data-api-key

# 번역 API — DeepL 또는 Google Translate 중 택1 (둘 다 비우면 mock 번역 사용)
DEEPL_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

# 데이터 소스 모드: mock | live
#  - mock : 실제 키 없이 샘플 데이터로 모든 기능 작동 (개발/시연용)
#  - live : 위 키들을 사용해 실데이터 연동 (배포용)
NEXT_PUBLIC_DATA_MODE=mock
